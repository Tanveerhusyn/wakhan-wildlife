# ─── Vercel Postgres ────────────────────────────────────────────────────────
# These are auto-populated when you connect a Vercel Postgres database
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Vercel Blob ─────────────────────────────────────────────────────────────
# Auto-populated when you connect a Vercel Blob store
BLOB_READ_WRITE_TOKEN=

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─── Admin credentials ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate hash: node -e "require('bcryptjs').hashSync('yourpassword', 12)" | pbcopy
ADMIN_PASSWORD_HASH=
